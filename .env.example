# ---- Osten-Sacken backend (.env) ----
# Скопіюй у .env та заповни реальними значеннями:  cp .env.example .env

# Порт локального Node-сервера (nginx проксіює сюди /api). Міняти не треба.
PORT=3000

# Resend API-ключ (https://resend.com → API Keys → Create)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Від кого йде лист.
#  • Поки домен НЕ верифіковано в Resend — став: onboarding@resend.dev
#    (у цьому режимі лист дійде ЛИШЕ на пошту власника акаунта Resend).
#  • Після верифікації домену ostensacken.com — став: Osten-Sacken <noreply@ostensacken.com>
FROM_EMAIL=onboarding@resend.dev

# Кому падає замовлення (пошта продавця)
TO_EMAIL=rishelie2003@gmail.com

# ---- Адмін-панель (/admin) ----
# Пароль для входу в адмінку (вигадай складний).
ADMIN_PASSWORD=
# Секрет для підпису сесійної cookie (довгий випадковий рядок).
# Згенерувати:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
