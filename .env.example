# ---- Osten-Sacken backend (.env) ----
# Скопіюй у .env та заповни реальними значеннями:  cp .env.example .env

# Порт локального Node-сервера (nginx проксіює сюди /api). Міняти не треба.
PORT=3000

# Resend API-ключ (https://resend.com → API Keys → Create)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Від кого йде лист.
#  • Поки домен НЕ верифіковано в Resend — став: onboarding@resend.dev
#    (у цьому режимі лист дійде ЛИШЕ на пошту власника акаунта Resend).
#  • Після верифікації домену ostensacken.com — став: Osten-Sacken <noreply@ostensacken.com>
FROM_EMAIL=onboarding@resend.dev

# Кому падає замовлення (пошта продавця)
TO_EMAIL=rishelie2003@gmail.com

# ---- Адмін-панель (/admin) ----
# РЕКОМЕНДОВАНО: зберігати не відкритий пароль, а його scrypt-хеш.
# Згенерувати:  node scripts/hash-password.js "ваш-складний-пароль"
# Вставити отриманий рядок сюди й НЕ заповнювати ADMIN_PASSWORD:
ADMIN_PASSWORD_HASH=
# Запасний варіант (менш безпечно): відкритий пароль. Використовується,
# лише якщо ADMIN_PASSWORD_HASH порожній. Для проду краще прибрати.
ADMIN_PASSWORD=
# (Необовʼязково) секрет — наразі не використовується для сесій
# (сесії серверні, id випадковий), лишено для сумісності.
SESSION_SECRET=
